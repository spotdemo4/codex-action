{
  "name": "codex-action",
  "version": "0.0.1",
  "description": "use codex in a GitHub/Gitea/Forgejo action",
  "license": "MIT",
  "repository": {
    "url": "https://trev.zip/llc/codex-action"
  },
  "bin": {
    "codex-action": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "rolldown -c",
    "dev": "rolldown -c && node build/index.js",
    "prepare": "rolldown -c && chmod +x build/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0",
    "@openai/codex-sdk": "^0.143.0",
    "libsodium-wrappers": "^0.8.4"
  },
  "devDependencies": {
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.3",
    "rolldown": "^1.1.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
